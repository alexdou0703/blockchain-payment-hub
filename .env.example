# Copy this file to .env and fill in the values before running docker compose.
# Never commit .env to version control.

# ── Blockchain (Sepolia testnet) ──────────────────────────────────────────────
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
SEPOLIA_WS_URL=wss://sepolia.infura.io/ws/v3/YOUR_INFURA_KEY

# Deployer hot wallet — the account at index [0] when deploy.ts ran
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Contract addresses — populated after: pnpm --filter contracts deploy:sepolia
ESCROW_CONTRACT_ADDRESS=0x
DISPUTE_CONTRACT_ADDRESS=0x
ORACLE_CONTRACT_ADDRESS=0x
SETTLEMENT_CONTRACT_ADDRESS=0x
USDT_ADDRESS=0x
TREASURY_ADDRESS=0x

# ── IPFS ─────────────────────────────────────────────────────────────────────
# Create a JWT at https://app.pinata.cloud/keys
PINATA_JWT=

# ── Frontend ─────────────────────────────────────────────────────────────────
# Create a project at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Defaults (override if needed) ────────────────────────────────────────────
# PORT=3001   (backend)
# PORT=3002   (oracle)
